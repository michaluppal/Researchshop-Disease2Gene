{
  "name": "researchshop-desktop",
  "version": "1.0.1",
  "description": "ResearchShop Desktop - AI-powered biomedical research analysis",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaluppal/Researchshop-Disease2Gene"
  },
  "author": {
    "name": "ResearchShop",
    "email": "researchshop@users.noreply.github.com"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --config config/electron.vite.config.ts",
    "build": "electron-vite build --config config/electron.vite.config.ts",
    "start": "electron-vite preview --config config/electron.vite.config.ts",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build --config config/electron.vite.config.ts && electron-builder --mac --config config/electron-builder.yml",
    "package:mac": "electron-vite build --config config/electron.vite.config.ts && electron-builder --mac --config config/electron-builder.yml",
    "package:mac:local": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build --config config/electron.vite.config.ts && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64 --config config/electron-builder.yml -c.mac.target=dmg",
    "package:win": "electron-vite build --config config/electron.vite.config.ts && electron-builder --win --config config/electron-builder.yml",
    "package:linux": "electron-vite build --config config/electron.vite.config.ts && electron-builder --linux --config config/electron-builder.yml",
    "assets:brand": "node app/scripts/generate-brand-assets.js",
    "typecheck:web": "tsc --noEmit -p config/tsconfig.web.json",
    "typecheck:node": "tsc --noEmit -p config/tsconfig.node.json",
    "typecheck": "npm run typecheck:web && npm run typecheck:node",
    "test": "vitest run --config config/vitest.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "csv-parse": "^5.5.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.400.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/papaparse": "^5.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.4"
  }
}
